{
  "name": "nexterm",
  "version": "1.0.0",
  "description": "AI 코딩 에이전트를 위한 Windows 터미널 멀티플렉서",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "node scripts/build-renderer.js",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "dev:watch": "node scripts/build-renderer.js --watch",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder --win --mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.9.0",
    "@xterm/addon-search": "^0.14.0",
    "@xterm/addon-webgl": "^0.17.0",
    "@xterm/xterm": "^5.4.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.nexterm.app",
    "productName": "NexTerm",
    "copyright": "Copyright © 2026 NexTerm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "NexTerm-${version}-Setup.${ext}",
      "signDlls": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NexTerm"
    },
    "portable": {
      "artifactName": "NexTerm-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "NexTerm-${version}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "NexTerm ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
