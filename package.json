{
  "name": "nexterm",
  "version": "1.0.0",
  "description": "AI 코딩 에이전트를 위한 Windows 터미널 멀티플렉서",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@xterm/xterm": "^5.4.0",
    "@xterm/addon-fit": "^0.9.0",
    "@xterm/addon-webgl": "^0.17.0",
    "@xterm/addon-search": "^0.14.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.nexterm.app",
    "productName": "NexTerm",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*.html",
      "src/renderer/**/*.css",
      "node_modules/**/*"
    ]
  }
}
